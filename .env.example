# 数据库密码（必须修改）
POSTGRES_PASSWORD=postgres

# 应用密钥（必须修改为随机字符串）
SECRET_KEY=change-me-in-production

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=8

# 对外端口
PORT=80

# 后端 Worker 数量
WORKERS=2

# ── AI / LLM 配置 ─────────────────────────────────────────────
# AI 总开关（false 则前端隐藏所有 AI 功能）
AI_ENABLED=false

# Provider 类型：openai_compatible（默认，覆盖绝大多数场景）| anthropic（直连 Claude API）
AI_PROVIDER=openai_compatible

# ── 方式一：公司内部 AI 网关（推荐）──────────────────────────
# 参考 ThemisAI / Aemeath 项目的网关接入方式
# 网关地址（内网 IP:Port），需加 /v1 后缀
# AI_BASE_URL=http://192.168.51.10:8080/v1
# 网关 Token（格式 gw-xxxx，走 Bearer Token 认证）
# AI_AUTH_TOKEN=gw-xxxx
# AI_API_KEY 留空（网关用 AUTH_TOKEN 认证，不需要 API Key）
# AI_API_KEY=

# ── 方式二：DeepSeek API ─────────────────────────────────────
# AI_BASE_URL=https://api.deepseek.com/v1
# AI_API_KEY=sk-xxxx
# AI_MODEL=deepseek-chat

# ── 方式三：阿里通义千问 ─────────────────────────────────────
# AI_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
# AI_API_KEY=sk-xxxx
# AI_MODEL=qwen-plus

# ── 方式四：本地 Ollama ──────────────────────────────────────
# AI_BASE_URL=http://localhost:11434/v1
# AI_API_KEY=ollama
# AI_MODEL=qwen2.5:7b

# ── 方式五：Anthropic 官方 ───────────────────────────────────
# AI_PROVIDER=anthropic
# AI_BASE_URL=https://api.anthropic.com
# AI_API_KEY=sk-ant-xxxx
# AI_MODEL=claude-sonnet-4-6

# ── 通用 LLM 参数 ────────────────────────────────────────────
AI_MODEL=claude-sonnet-4-6
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=120
