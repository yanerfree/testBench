# 数据库密码（必须修改）
POSTGRES_PASSWORD=postgres

# 应用密钥（必须修改为随机字符串）
SECRET_KEY=change-me-in-production

# JWT 过期时间（小时）
JWT_EXPIRE_HOURS=8

# 对外端口
PORT=80

# 后端 Worker 数量
WORKERS=2

# AI / LLM 配置
AI_ENABLED=false
AI_PROVIDER=openai_compatible          # openai_compatible | anthropic
AI_BASE_URL=                           # 公司 AI 网关地址，如 https://gw.company.com/v1
AI_API_KEY=                            # API Key（标准 OpenAI 模式）
AI_AUTH_TOKEN=                         # Bearer Token（公司网关认证）
AI_MODEL=claude-sonnet-4-6            # 模型名
AI_MAX_TOKENS=4096
AI_TEMPERATURE=0.3
AI_TIMEOUT_SECONDS=120
